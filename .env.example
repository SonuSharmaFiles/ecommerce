# ============================================================
# ShopFlow — Environment configuration
# Copy to `.env.local` for dev. Set in Vercel for production.
# ============================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ShopFlow
NEXT_PUBLIC_DEFAULT_CURRENCY=USD
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct database (for migrations / scripts)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Stripe
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_ENV=sandbox

# Resend (transactional email)
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=ShopFlow <noreply@shopflow.io>

# Redis (Upstash for serverless; or self-hosted)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=

# AI
ANTHROPIC_API_KEY=

# Dropshipping integrations
CJ_DROPSHIPPING_API_KEY=
CJ_DROPSHIPPING_EMAIL=
AUTODS_API_KEY=
AUTODS_STORE_ID=

# Currency conversion
EXCHANGE_RATES_API_KEY=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Storage (Cloudflare R2 / Supabase)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Cron / job security
CRON_SECRET=

# Admin bootstrap
ADMIN_BOOTSTRAP_EMAIL=
